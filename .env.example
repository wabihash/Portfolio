# ==============================================================================
# PORTFOLIO ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================

# 1. AI Assistant (Primary: Gemini)
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2. AI Assistant (Fallback: GitHub Models)
# Get a Personal Access Token (PAT) from GitHub Settings
GITHUB_MODELS_API_KEY=your_github_pat_here
GITHUB_MODELS_MODEL=openai/gpt-4o-mini

# 3. Contact Form (Nodemailer / Gmail SMTP)
# For Gmail, you MUST use an "App Password" (16 characters)
# Tutorial: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
CONTACT_FROM_EMAIL=your_email@gmail.com
CONTACT_TO_EMAIL=your_email@gmail.com

# 4. App Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
SHOW_RESET_LINK=false
